// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: {userId}
// Fields:
//   - uid: string (required)
//   - email: string (required)
//   - displayName: string
//   - photoURL: string
//   - role: string (required, 'admin', 'manager', 'staff')
//
// Collection: products
// Document ID: {productId} (sku)
// Fields:
//   - sku: string (required)
//   - name: string (required)
//   - category: string (required)
//
// Collection: ticketsA
// Document ID: {date} (YYYY-MM-DD)
// Fields:
//   - sends: list (array of SendOperation objects)
//   - receives: map (workshop -> list of ReceiveOperation objects)
//
// Collection: ticketsB
// Document ID: {date} (YYYY-MM-DD)
// Fields:
//   - items: list (array of TicketBItem objects)
//
// Collection: settings
// Document ID: global
// Fields:
//   - workshops: list (array of strings)
//   - types: list (array of strings)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (request.auth.token.email == "trungg9870@gmail.com" || 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    function isManager() {
      return isAuthenticated() &&
        (isAdmin() || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'manager');
    }

    function isStaff() {
      return isAuthenticated();
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['sku', 'name', 'category']) &&
             data.sku is string && data.sku.size() > 0 && data.sku.size() < 100 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 500 &&
             data.category is string && data.category.size() > 0 && data.category.size() < 200;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string && data.email is string &&
             data.role in ['admin', 'manager', 'staff'];
    }

    function isValidSettings(data) {
      return data.keys().hasAll(['workshops', 'types']) &&
             data.workshops is list && data.types is list;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow get: if isAuthenticated();
      allow list: if isAdmin();
      allow create: if isAuthenticated() && (request.auth.uid == userId || isAdmin()) && isValidUser(request.resource.data);
      allow update: if isAuthenticated() && (request.auth.uid == userId || isAdmin()) && isValidUser(request.resource.data);
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if isStaff();
      allow write: if isManager() && isValidProduct(request.resource.data);
    }

    match /ticketsA/{date} {
      allow read: if isStaff();
      allow write: if isStaff();
    }

    match /ticketsB/{date} {
      allow read: if isStaff();
      allow write: if isStaff();
    }

    match /settings/{settingId} {
      allow read: if isStaff();
      allow write: if isAdmin() && isValidSettings(request.resource.data);
    }
  }
}
